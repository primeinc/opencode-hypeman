{
    "$schema": "https://json.schemastore.org/package.json",
    "name": "@primeinc/opencode-hypeman",
    "version": "0.1.0",
    "type": "module",
    "description": "OpenCode plugin that transforms user prompts into high-energy 'Hypeman' register while preserving semantic integrity",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "scripts": {
        "clean": "rm -rf dist",
        "build": "npm run clean && tsc",
        "postbuild": "rm -rf dist/logs",
        "prepublishOnly": "npm run build",
        "dev": "opencode plugin dev",
        "typecheck": "tsc --noEmit",
        "test": "node --import tsx --test tests/*.test.ts",
        "format": "prettier --write .",
        "format:check": "prettier --check ."
    },
    "keywords": [
        "opencode",
        "opencode-plugin",
        "plugin",
        "prompt",
        "transformation",
        "affective-mirroring",
        "hypeman"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/primeinc/opencode-hypeman.git"
    },
    "bugs": {
        "url": "https://github.com/primeinc/opencode-hypeman/issues"
    },
    "homepage": "https://github.com/primeinc/opencode-hypeman#readme",
    "author": "primeinc",
    "license": "MIT",
    "peerDependencies": {
        "@opencode-ai/plugin": ">=0.13.7"
    },
    "dependencies": {
        "jsonc-parser": "^3.3.1"
    },
    "devDependencies": {
        "@opencode-ai/plugin": "^1.0.143",
        "@types/node": "^24.10.1",
        "prettier": "^3.4.2",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3"
    },
    "files": [
        "dist/",
        "README.md",
        "LICENSE"
    ]
}
